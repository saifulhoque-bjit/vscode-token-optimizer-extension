{
  "name": "vscode-copilot-token-optimizer",
  "displayName": "Copilot Token Optimizer",
  "description": "Optimize Copilot token usage with automatic compression, cache alignment, concise rewriting, structured output, and context tracking",
  "version": "2.0.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tokenOptimizer",
          "title": "Token Optimizer",
          "icon": "$(zap)"
        }
      ]
    },
    "views": {
      "tokenOptimizer": [
        {
          "id": "tokenOptimizer.sidebar",
          "name": "Controls",
          "type": "webview"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "optimize",
        "name": "Optimize",
        "description": "Optimize token usage (optional \u2014 use sidebar for primary control)",
        "isSticky": true
      }
    ],
    "commands": [
      {
        "command": "tokenOptimizer.toggleAll",
        "title": "Token Optimizer: Toggle All Optimizations",
        "icon": "$(zap)"
      },
      {
        "command": "tokenOptimizer.clearContext",
        "title": "Token Optimizer: Clear Context"
      },
      {
        "command": "optimize.clearContext",
        "title": "Clear optimization context"
      }
    ],
    "configuration": {
      "title": "Token Optimizer",
      "properties": {
        "tokenOptimizer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Master switch \u2014 enable/disable all optimizations"
        },
        "tokenOptimizer.compression": {
          "type": "boolean",
          "default": true,
          "description": "Extract file signatures instead of full source code"
        },
        "tokenOptimizer.contentRouter": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect and compress diffs, logs, search results, JSON"
        },
        "tokenOptimizer.cacheAlign": {
          "type": "boolean",
          "default": true,
          "description": "Use static prefix for prompt caching efficiency"
        },
        "tokenOptimizer.conciseRewrite": {
          "type": "boolean",
          "default": true,
          "description": "Strip verbose phrases and polite filler from prompts"
        },
        "tokenOptimizer.structuredOutput": {
          "type": "boolean",
          "default": true,
          "description": "Detect task type and add response format instructions"
        },
        "tokenOptimizer.contextTracking": {
          "type": "boolean",
          "default": true,
          "description": "Track cross-turn Q&A for follow-up context"
        }
      }
    }
  },
  "categories": [
    "Other"
  ],
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.0.0"
  },
  "publisher": "saifulhoque-bjit",
  "repository": {
    "type": "git",
    "url": "https://github.com/saifulhoque-bjit/vscode-token-optimizer-extension.git"
  }
}